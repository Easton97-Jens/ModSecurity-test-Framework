{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://modsecurity-connector.invalid/schemas/no-crs-result-v1.json",
  "title": "Canonical No-CRS connector result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status_model", "connector", "run_id", "connector_commit", "framework_commit", "connector_worktree_clean", "framework_worktree_clean", "provenance_required", "connector_commit_at_finalize", "framework_commit_at_finalize", "host_name", "host_version", "integration_mode", "artifact_profile", "host_profile", "executed_targets", "libmodsecurity_version", "evidence_stage", "evidence_stages", "ruleset", "status", "exit_code", "source_statuses", "source_failure", "blocked_before_execution", "started", "requests_sent", "allowed_request_status", "blocked_request_status", "observed_rule_ids", "transaction_ids", "request_headers_verified", "request_body_verified", "response_headers_verified", "response_body_verified", "late_intervention_verified", "phase4_case_results", "event_metadata_verified", "body_payload_absent_from_events", "pass_gate_failures", "cases_total", "cases_passed", "cases_failed", "cases_blocked", "cases_unsupported", "cases_not_applicable", "cases_not_executed", "status_counts", "group_statuses", "capabilities_verified", "capabilities_unsupported", "capabilities_not_exercised", "capability_states", "artifacts", "claims_not_allowed", "production_ready", "security_verified", "crs_verified", "crs_complete", "full_matrix_ready", "started_at", "ended_at"],
  "properties": {
    "schema_version": {"const": 1},
    "status_model": {"const": "msconnector_status"},
    "connector": {"enum": ["apache", "nginx", "haproxy", "envoy", "traefik", "lighttpd"]},
    "run_id": {"type": "string", "minLength": 1},
    "connector_commit": {"type": "string", "minLength": 1},
    "framework_commit": {"type": "string", "minLength": 1},
    "connector_worktree_clean": {"type": "boolean"},
    "framework_worktree_clean": {"type": "boolean"},
    "provenance_required": {"type": "boolean"},
    "connector_commit_at_finalize": {"type": "string", "minLength": 1},
    "framework_commit_at_finalize": {"type": "string", "minLength": 1},
    "host_name": {"type": "string", "minLength": 1},
    "host_version": {"type": "string", "minLength": 1},
    "integration_mode": {"type": "string", "minLength": 1},
    "host_profile": {"type": "string", "minLength": 1},
    "executed_targets": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1},
    "libmodsecurity_version": {"type": "string", "minLength": 1},
    "evidence_stage": {"enum": ["minimal_runtime_smoke", "no_crs_baseline"]},
    "artifact_profile": {"enum": ["generic", "full_lifecycle"]},
    "evidence_stages": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_contract", "compile", "link", "config_load", "start_smoke", "minimal_runtime_smoke", "no_crs_baseline", "crs_smoke", "extended_matrix"],
      "properties": {
        "source_contract": {"$ref": "#/$defs/evidence_stage"},
        "compile": {"$ref": "#/$defs/evidence_stage"},
        "link": {"$ref": "#/$defs/evidence_stage"},
        "config_load": {"$ref": "#/$defs/evidence_stage"},
        "start_smoke": {"$ref": "#/$defs/evidence_stage"},
        "minimal_runtime_smoke": {"$ref": "#/$defs/evidence_stage"},
        "no_crs_baseline": {"$ref": "#/$defs/evidence_stage"},
        "crs_smoke": {"$ref": "#/$defs/evidence_stage"},
        "extended_matrix": {"$ref": "#/$defs/evidence_stage"}
      }
    },
    "ruleset": {"const": "no-crs-baseline"},
    "status": {"enum": ["PASS", "FAIL", "BLOCKED", "UNSUPPORTED", "NOT_APPLICABLE", "NOT_EXECUTED"]},
    "exit_code": {"type": "integer"},
    "blocked_before_execution": {"type": "boolean"},
    "started": {"type": "boolean"},
    "requests_sent": {"type": "boolean"},
    "source_statuses": {"type": "array", "items": {"type": "string"}},
    "source_failure": {"type": "boolean"},
    "allowed_request_status": {"type": ["integer", "null"]},
    "blocked_request_status": {"type": ["integer", "null"]},
    "observed_rule_ids": {"type": "array", "items": {"type": "integer"}, "uniqueItems": true},
    "transaction_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "request_headers_verified": {"type": "boolean"},
    "request_body_verified": {"type": "boolean"},
    "response_headers_verified": {"type": "boolean"},
    "response_body_verified": {"type": "boolean"},
    "late_intervention_verified": {"type": "boolean"},
    "phase4_case_results": {
      "type": "array",
      "items": {"$ref": "#/$defs/phase4_case_result"}
    },
    "event_metadata_verified": {"type": "boolean"},
    "body_payload_absent_from_events": {"type": "boolean"},
    "pass_gate_failures": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "cases_total": {"type": "integer", "minimum": 0},
    "cases_passed": {"type": "integer", "minimum": 0},
    "cases_failed": {"type": "integer", "minimum": 0},
    "cases_blocked": {"type": "integer", "minimum": 0},
    "cases_unsupported": {"type": "integer", "minimum": 0},
    "cases_not_applicable": {"type": "integer", "minimum": 0},
    "cases_not_executed": {"type": "integer", "minimum": 0},
    "status_counts": {
      "type": "object",
      "required": ["PASS", "FAIL", "BLOCKED", "UNSUPPORTED", "NOT_APPLICABLE", "NOT_EXECUTED"],
      "additionalProperties": false,
      "properties": {
        "PASS": {"type": "integer", "minimum": 0},
        "FAIL": {"type": "integer", "minimum": 0},
        "BLOCKED": {"type": "integer", "minimum": 0},
        "UNSUPPORTED": {"type": "integer", "minimum": 0},
        "NOT_APPLICABLE": {"type": "integer", "minimum": 0},
        "NOT_EXECUTED": {"type": "integer", "minimum": 0}
      }
    },
    "group_statuses": {
      "type": "object",
      "additionalProperties": {"enum": ["PASS", "FAIL", "BLOCKED", "UNSUPPORTED", "NOT_APPLICABLE", "NOT_EXECUTED"]}
    },
    "capabilities_verified": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "capabilities_unsupported": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "capabilities_not_exercised": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "capability_states": {
      "type": "object",
      "additionalProperties": {"enum": ["verified", "implemented_not_asserted", "configured_not_exercised", "unsupported_by_host_model", "not_implemented", "not_applicable"]}
    },
    "artifacts": {"type": "object", "additionalProperties": {"type": "string", "minLength": 1}},
    "claims_not_allowed": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "production_ready": {"const": false},
    "security_verified": {"const": false},
    "crs_verified": {"const": false},
    "crs_complete": {"const": false},
    "full_matrix_ready": {"const": false},
    "started_at": {"type": "string", "minLength": 1},
    "ended_at": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "phase4_case_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_id", "status", "live_executed", "expected_result", "expected_rule_id", "observed_rule_ids", "transaction_ids", "http_status", "requested_action", "actual_action", "original_http_status", "visible_http_status", "late_intervention", "headers_sent", "response_started", "body_started", "body_truncated", "response_committed", "connection_aborted", "transport_result", "late_intervention_mode", "content_type_scope", "body_limit_outcome", "marker_split_across_chunks", "end_of_stream_evaluation", "no_full_response_buffering", "first_byte_before_response_end", "upstream_response_finished_at_first_byte", "client_first_byte_received", "first_chunk_size", "upstream_paused", "upstream_eos_sent_at_first_byte", "transport_protocol", "transfer_encoding", "connection_reused", "client_aborted", "upstream_aborted"],
      "properties": {
        "case_id": {"type": "string", "pattern": "^phase4_[a-z0-9_]+$"},
        "status": {"enum": ["PASS", "FAIL", "BLOCKED", "UNSUPPORTED", "NOT_APPLICABLE", "NOT_EXECUTED"]},
        "live_executed": {"type": "boolean"},
        "expected_result": {"type": "string", "minLength": 1},
        "expected_rule_id": {"type": ["integer", "null"]},
        "observed_rule_ids": {"type": "array", "items": {"type": "integer"}, "uniqueItems": true},
        "transaction_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "http_status": {"type": ["integer", "null"], "minimum": 0, "maximum": 999},
        "requested_action": {"type": ["string", "null"], "enum": ["deny", "redirect", "drop", "log_only", "abort_connection", null]},
        "actual_action": {"type": ["string", "null"], "enum": ["deny", "redirect", "log_only", "abort_connection", null]},
        "original_http_status": {"type": ["integer", "null"], "minimum": 0, "maximum": 999},
        "visible_http_status": {"type": ["integer", "null"], "minimum": 0, "maximum": 999},
        "late_intervention": {"type": ["boolean", "null"]},
        "headers_sent": {"type": ["boolean", "null"]},
        "response_started": {"type": ["boolean", "null"]},
        "body_started": {"type": ["boolean", "null"]},
        "body_truncated": {"type": ["boolean", "null"]},
        "response_committed": {"type": ["boolean", "null"]},
        "connection_aborted": {"type": ["boolean", "null"]},
        "transport_result": {"type": ["string", "null"], "enum": ["http_status", "log_only", "connection_aborted", "not_observable", null]},
        "late_intervention_mode": {"type": ["string", "null"], "enum": ["minimal", "safe", "strict", null]},
        "content_type_scope": {"type": ["string", "null"], "enum": ["in_scope", "out_of_scope", "missing", null]},
        "body_limit_outcome": {"type": ["string", "null"], "enum": ["at_limit", "over_limit", "process_partial", "reject", null]},
        "marker_split_across_chunks": {"type": ["boolean", "null"]},
        "end_of_stream_evaluation": {"type": ["boolean", "null"]},
        "no_full_response_buffering": {"type": ["boolean", "null"]},
        "first_byte_before_response_end": {"type": ["boolean", "null"]},
        "upstream_response_finished_at_first_byte": {"type": ["boolean", "null"]},
        "client_first_byte_received": {"type": ["boolean", "null"]},
        "first_chunk_size": {"type": ["integer", "null"], "minimum": 0},
        "upstream_paused": {"type": ["boolean", "null"]},
        "upstream_eos_sent_at_first_byte": {"type": ["boolean", "null"]},
        "transport_protocol": {"type": ["string", "null"], "enum": ["http1", "http2", null]},
        "transfer_encoding": {"type": ["string", "null"], "enum": ["content_length", "chunked", "none", null]},
        "connection_reused": {"type": ["boolean", "null"]},
        "client_aborted": {"type": ["boolean", "null"]},
        "upstream_aborted": {"type": ["boolean", "null"]}
      }
    },
    "evidence_stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason"],
      "properties": {
        "status": {"enum": ["supported_and_verified", "supported_not_verified", "implemented_not_asserted", "unsupported_by_host_model", "not_implemented", "blocked_before_execution", "failed", "not_executed", "not_applicable"]},
        "reason": {"type": "string", "minLength": 1},
        "evidence": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      }
    }
  }
}

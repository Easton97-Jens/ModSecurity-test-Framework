{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://modsecurity-connector.invalid/schemas/no-crs-effective-config-v1.json",
  "title": "Payload-free effective configuration inventory",
  "description": "Hashes and bounded relative labels only; raw configuration values, secrets, and request data are intentionally excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "connector", "integration_mode", "run_id", "files"],
  "properties": {
    "schema_version": {"const": 1},
    "connector": {"enum": ["apache", "nginx", "haproxy", "envoy", "traefik", "lighttpd"]},
    "integration_mode": {"type": "string", "minLength": 1, "maxLength": 64, "pattern": "[A-Za-z0-9:._-]{1,64}"},
    "run_id": {"type": "string", "minLength": 1, "maxLength": 256, "pattern": "[A-Za-z0-9:._-]{1,256}"},
    "files": {
      "type": "array",
      "maxItems": 256,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {"type": "string", "minLength": 1, "maxLength": 256, "pattern": "[A-Za-z0-9._/-]{1,256}"},
          "sha256": {"type": "string", "pattern": "[0-9a-f]{64}"}
        }
      }
    }
  }
}

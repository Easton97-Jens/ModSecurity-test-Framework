{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://modsecurity-connector.invalid/schemas/no-crs-case-result-v1.json",
  "title": "Canonical No-CRS case result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "connector", "case_id", "group", "phase", "required_capabilities", "status", "operation_status", "live_executed", "expected_result", "observed_result", "expected_status", "actual_status", "expected_rule_id", "observed_rule_ids", "transaction_ids", "expected_event_fields", "observed_event_fields", "event_metadata_verified", "http_status", "requested_action", "actual_action", "original_http_status", "visible_http_status", "late_intervention", "headers_sent", "response_started", "body_started", "body_truncated", "response_committed", "connection_aborted", "transport_result", "late_intervention_mode", "content_type_scope", "body_limit_outcome", "marker_split_across_chunks", "end_of_stream_evaluation", "no_full_response_buffering", "first_byte_before_response_end", "upstream_response_finished_at_first_byte", "transport_protocol", "transfer_encoding", "connection_reused", "client_aborted", "upstream_aborted", "reason", "exit_code", "artifacts"],
  "properties": {
    "schema_version": {"const": 1},
    "connector": {"enum": ["apache", "nginx", "haproxy", "envoy", "traefik", "lighttpd"]},
    "case_id": {"type": "string", "minLength": 1},
    "group": {"type": "string", "minLength": 1},
    "phase": {"type": "integer", "minimum": 0, "maximum": 5},
    "status": {"enum": ["PASS", "FAIL", "BLOCKED", "UNSUPPORTED", "NOT_APPLICABLE", "NOT_EXECUTED"]},
    "operation_status": {"enum": ["ok", "error", "blocked", "unsupported"]},
    "live_executed": {"type": "boolean"},
    "required_capabilities": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
    "expected_result": {"type": "string", "minLength": 1},
    "observed_result": {"type": ["string", "null"]},
    "expected_status": {"type": ["integer", "null"]},
    "actual_status": {"type": ["integer", "null"]},
    "expected_rule_id": {"type": ["integer", "null"]},
    "observed_rule_ids": {"type": "array", "items": {"type": "integer"}, "uniqueItems": true},
    "transaction_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "expected_event_fields": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "observed_event_fields": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "event_metadata_verified": {"type": "boolean"},
    "http_status": {"type": ["integer", "null"], "minimum": 0, "maximum": 999},
    "requested_action": {"type": ["string", "null"], "enum": ["deny", "redirect", "drop", "log_only", "abort_connection", null]},
    "actual_action": {"type": ["string", "null"], "enum": ["deny", "redirect", "log_only", "abort_connection", null]},
    "original_http_status": {"type": ["integer", "null"], "minimum": 0, "maximum": 999},
    "visible_http_status": {"type": ["integer", "null"], "minimum": 0, "maximum": 999},
    "late_intervention": {"type": ["boolean", "null"]},
    "headers_sent": {"type": ["boolean", "null"]},
    "response_started": {"type": ["boolean", "null"]},
    "body_started": {"type": ["boolean", "null"]},
    "body_truncated": {"type": ["boolean", "null"]},
    "response_committed": {"type": ["boolean", "null"]},
    "connection_aborted": {"type": ["boolean", "null"]},
    "transport_result": {"type": ["string", "null"], "enum": ["http_status", "log_only", "connection_aborted", "not_observable", null]},
    "late_intervention_mode": {"type": ["string", "null"], "enum": ["minimal", "safe", "strict", null]},
    "content_type_scope": {"type": ["string", "null"], "enum": ["in_scope", "out_of_scope", "missing", null]},
    "body_limit_outcome": {"type": ["string", "null"], "enum": ["at_limit", "over_limit", "process_partial", "reject", null]},
    "marker_split_across_chunks": {"type": ["boolean", "null"]},
    "end_of_stream_evaluation": {"type": ["boolean", "null"]},
    "no_full_response_buffering": {"type": ["boolean", "null"]},
    "first_byte_before_response_end": {"type": ["boolean", "null"]},
    "upstream_response_finished_at_first_byte": {"type": ["boolean", "null"]},
    "transport_protocol": {"type": ["string", "null"], "enum": ["http1", "http2", null]},
    "transfer_encoding": {"type": ["string", "null"], "enum": ["content_length", "chunked", "none", null]},
    "connection_reused": {"type": ["boolean", "null"]},
    "client_aborted": {"type": ["boolean", "null"]},
    "upstream_aborted": {"type": ["boolean", "null"]},
    "reason": {"type": "string"},
    "exit_code": {"type": ["integer", "null"]},
    "artifacts": {"type": "object", "additionalProperties": {"type": "string", "minLength": 1}}
  }
}
